# Populate these with your pipeline secrets before running in CI
baseUrl=https://oneroster.example.com
apiVirtualName=api
oneRosterVirtualName=oneroster-api
oneRosterVersion=ims/oneroster/rostering/v1p2
clientId=__ONEROSTER_CLIENT_ID__
clientSecret=__ONEROSTER_CLIENT_SECRET__
oauthScope=api
verifyTls=true

edfiBaseUrl=https://ods.example.com/api
edfiClientId=__ODS_CLIENT_ID__
edfiClientSecret=__ODS_CLIENT_SECRET__
dataStandardVersion=__DATA_STANDARD_VERSION__
databaseBackend=__DATABASE_BACKEND__
