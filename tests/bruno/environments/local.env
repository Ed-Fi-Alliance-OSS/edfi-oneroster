# Local compose defaults. Update values if your docker-compose.env differs.
baseUrl=https://localhost
apiVirtualName=api
oneRosterVirtualName=oneroster-api
oneRosterVersion=ims/oneroster/rostering/v1p2
clientId=populated-key
clientSecret=populated-secret
oauthScope=api
verifyTls=false

# Optional: backing ODS API information for future parity assertions
edfiBaseUrl=https://localhost/api
edfiClientId=populated-key
edfiClientSecret=populated-secret
dataStandardVersion=DS5
databaseBackend=PostgreSQL
