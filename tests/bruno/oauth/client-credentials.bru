meta {
  name: obtain client credentials token
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/{{apiVirtualName}}/oauth/token
  body: formUrlEncoded
  auth: basic
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

auth:basic {
  username: {{client_id}}
  password: {{client_secret}}
}

body:form-urlencoded {
  grant_type: client_credentials
  scope: https://purl.imsglobal.org/spec/or/v1p2/scope/roster-demographics.readonly
  client_id: lea-key
  client_secret: lea-secret
}

script:post-response {
  const payload = res.getBody();
  if (!payload || !payload.access_token) {
    throw new Error('access_token missing in OAuth response');
  }
  env.set('accessToken', payload.access_token);
  env.set('tokenExpiresIn', payload.expires_in || 0);
}

tests {
  test("token endpoint succeeded", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("access token returned", function() {
    const payload = res.getBody();
    expect(payload).to.have.property('access_token');
  });
}
