meta {
  name: Get Lea Token
  type: http
  seq: 1
}

post {
  url: {{oauthUrl}}
  body: json
  auth: inherit
}

body:json {
  {
    "grant_type": "client_credentials",
    "client_id": "{{leaClientId}}",
    "client_secret": "{{leaClientSecret}}",
    "scope": "{{oauthScope}}"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    const response = res.getBody();
    const currentSeconds = new Date().getTime() / 1000;
    bru.setEnvVar('lea-odsApiToken', response.access_token);
    bru.setEnvVar('lea-odsApiTokenExpiration', currentSeconds + response.expires_in);
    console.log('Token generated successfully!');
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
