meta {
  name: list enrollments
  type: http
  seq: 5
}

get {
  url: {{oneRosterUrl}}/{{rosterPath}}/enrollments?limit=20000&offset=0&orderBy=asc
  body: none
  auth: bearer
}

auth:bearer {
  token: {{lea-odsApiToken}}
}

script:pre-request {
  const token = bru.getEnvVar('lea-odsApiToken');
  if (!token) {
    throw new Error('Run the oauth folder to populate accessToken before calling OneRoster endpoints.');
  }
}

script:post-response {
  const payload = res.getBody();
  const enrollments = Array.isArray(payload?.enrollments) ? payload.enrollments : payload;
  if (Array.isArray(enrollments) && enrollments.length > 0) {
    bru.setVar('sampleEnrollment', enrollments[0]);
  }
}

tests {
  test("request succeeded", function() {
    expect(res.getStatus()).to.equal(200);
    console.log("request succeeded");
  });

  test("number of records retrieved", function() {
    const enrollments = Array.isArray(res.getBody()?.enrollments) ? res.getBody().enrollments : res.getBody();
    console.log("number of records retrieved: " + (Array.isArray(enrollments) ? enrollments.length : 0));
  });
}
