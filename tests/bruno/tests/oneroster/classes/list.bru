meta {
  name: list classes
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/{{oneRosterVirtualName}}/{{rosterPath}}/classes?limit=5000&offset=0&orderBy=asc
  body: none
  auth: bearer
}

auth:bearer {
  token: {{lea-odsApiToken}}
}

script:pre-request {
  const token = bru.getEnvVar('lea-odsApiToken');
  if (!token) {
    throw new Error('Run the oauth folder to populate accessToken before calling OneRoster endpoints.');
  }
}

script:post-response {
  const payload = res.getBody();
  const classes = Array.isArray(payload?.classes) ? payload.classes : payload;
  if (Array.isArray(classes) && classes.length > 0) {
    bru.setVar('sampleClass', classes[0]);
  }
}

tests {
  test("request succeeded", function() {
    expect(res.getStatus()).to.equal(200);
    console.log("request succeeded");
  });

  test("number of records retrieved", function() {
    const classes = Array.isArray(res.getBody()?.classes) ? res.getBody().classes : res.getBody();
    console.log("number of records retrieved: " + (Array.isArray(classes) ? classes.length : 0));
  });
}
