meta {
  name: Get Lea Token
  type: http
  seq: 1
}

post {
  url: {{tenant1OauthUrl}}
  body: json
  auth: inherit
}

body:json {
  {
    "grant_type": "client_credentials",
    "client_id": "{{tenant1LeaClientId}}",
    "client_secret": "{{tenant1LeaClientSecret}}",
    "scope": "{{oauthScope}}"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    const response = res.getBody();
    const currentSeconds = new Date().getTime() / 1000;
    bru.setEnvVar('tenant1-lea-odsApiToken', response.access_token);
    bru.setEnvVar('tenant1-lea-odsApiTokenExpiration', currentSeconds + response.expires_in);
    console.log('Tenant1 LEA token generated successfully!');
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
