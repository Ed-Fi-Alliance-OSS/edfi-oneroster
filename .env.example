# Update the database username and password values before deployment.
# Use environment-appropriate credentials and avoid default credentials.

# OneRoster API port to serve on:
PORT=3000

# Optional base path when hosted behind IIS virtual directory (for deterministic discovery URLs)
# Example: /oneroster
API_BASE_PATH=

# Database type: 'postgres' or 'mssql'
DB_TYPE=postgres

# Encryption key for ODS connection strings stored in EdFi_Admin.OdsInstances
# Generate with: openssl rand -base64 32
# This is REQUIRED - without it, ODS connections cannot be decrypted
# Value must match the ODS API ApiSettings:OdsConnectionStringEncryptionKey configuration value.
ODS_CONNECTION_STRING_ENCRYPTION_KEY=

# SINGLE-TENANT MODE (Default EdFi_Admin Connection)
# For PostgreSQL (example):
# CONNECTION_CONFIG={"adminConnection":"host=localhost;port=5432;database=EdFi_Admin;username=postgres;password=<your_db_password>"}
# For MSSQL (example):
CONNECTION_CONFIG={"adminConnection":"server=localhost;database=EdFi_Admin;user id=sa;password=<your_db_password>;encrypt=false;TrustServerCertificate=true"}

# Optional: ODS instance connection strings (single-tenant mode).
# When set, ODS connections are resolved from here instead of querying EdFi_Admin.OdsInstances.
# Each instance requires ConnectionString. Add ContextValueByKey only when using ODS_CONTEXT_ROUTE_TEMPLATE.
# Connection strings can be plain text or encrypted (detected automatically).
# Example: ODS_INSTANCES={"3":{"ConnectionString":"Server=localhost;Database=EdFi_Ods_2026;user id=sa;password=<pwd>;encrypt=false","ContextValueByKey":{"schoolYearFromRoute":"2026"}},"4":{"ConnectionString":"Server=localhost;Database=EdFi_Ods_2027;user id=sa;password=<pwd>;encrypt=false"}}
# Leave empty to resolve ODS connections from the EdFi_Admin database (default).
ODS_INSTANCES=

# set to `prod` or `` (empty) for production
NODE_ENV=dev

# pg-boss settings (PostgreSQL only):
# Explicit PostgreSQL admin connection used for pg-boss metadata storage.
# Valid options:
# - Tenant admin DB (multi-tenant mode)
# - Same admin DB referenced by CONNECTION_CONFIG (single-tenant mode)
# - Dedicated pg-boss database
# Example:
# PG_BOSS_CONNECTION_CONFIG={"adminConnection":"host=localhost;port=5432;database=EdFi_Admin;username=postgres;password=<your_db_password>"}
PG_BOSS_CONNECTION_CONFIG=
PGBOSS_CRON=*/15 * * * *

# OAuth2 settings - these must be filled out!
OAUTH2_ISSUERBASEURL=https://dev-5n8uf6ov.us.auth0.com/
OAUTH2_AUDIENCE=http://localhost:3000
OAUTH2_TOKENSIGNINGALG=RS256

# PEM-encoded public key for verifying JWTs.
# This is only a placeholder. Replace with your full multi-line PEM public key,
# encoded on a single line using '\n' between lines, including the END marker.
# Value must match the Security:Jwt:SigningKey:PublicKey configuration value in the ODS API appsettings.json.
# Example:
# OAUTH2_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...\n-----END PUBLIC KEY-----
OAUTH2_PUBLIC_KEY_PEM=

# Comma-separated list of allowed CORS origins
# Example: http://localhost:3000,http://localhost:56641/ (ODS API Swagger UI)
CORS_ORIGINS=http://localhost:3000

# Rate limiting settings
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# trust proxy tells your Node/Express app that it is running behind a reverse proxy (like IIS/ARR/nginx) and should trust forwarded headers.
TRUST_PROXY=false

# Multi-tenancy settings
MULTITENANCY_ENABLED=false

# PostgreSQL example:
# TENANTS_CONNECTION_CONFIG={"Tenant1":{"adminConnection":"host=localhost;port=5432;database=EdFi_Admin_Tenant1;username=postgres;password=<tenant1_db_password>"},"Tenant2":{"adminConnection":"host=localhost;port=5432;database=EdFi_Admin_Tenant2;username=postgres;password=<tenant2_db_password>"}}
#
# MSSQL example:
# TENANTS_CONNECTION_CONFIG={"Tenant1":{"adminConnection":"server=localhost;database=EdFi_Admin_Tenant1;user id=sa;password=<tenant1_db_password>;encrypt=false"},"Tenant2":{"adminConnection":"server=localhost;database=EdFi_Admin_Tenant2;user id=sa;password=<tenant2_db_password>;encrypt=false"}}
#
# Optional: each tenant can include OdsInstances to define ODS connections directly instead of querying its EdFi_Admin database.
# ContextValueByKey is optional per instance — only needed when ODS_CONTEXT_ROUTE_TEMPLATE is configured.
#
# MSSQL example with OdsInstances and context routing:
# TENANTS_CONNECTION_CONFIG={"Tenant1":{"adminConnection":"server=localhost;database=EdFi_Admin_Tenant1;user id=sa;password=<tenant1_db_password>;encrypt=false","OdsInstances":{"3":{"ConnectionString":"Server=localhost;Database=EdFi_Ods_Tenant1_2026;user id=sa;password=<ods_password>;encrypt=false","ContextValueByKey":{"schoolYearFromRoute":"2026"}},"4":{"ConnectionString":"Server=localhost;Database=EdFi_Ods_Tenant1_2027;user id=sa;password=<ods_password>;encrypt=false","ContextValueByKey":{"schoolYearFromRoute":"2027"}}}},"Tenant2":{"adminConnection":"server=localhost;database=EdFi_Admin_Tenant2;user id=sa;password=<tenant2_db_password>;encrypt=false"}}
# Tenants without OdsInstances fall back to database-based ODS instance resolution.
TENANTS_CONNECTION_CONFIG=

# Ods context route template
# Examples:
#   ODS_CONTEXT_ROUTE_TEMPLATE={schoolYearFromRoute:range(2026,2027)}
# Leave empty to disable context routing
ODS_CONTEXT_ROUTE_TEMPLATE=

# Optional HTTPS/TLS for the OneRoster API process
# When ENABLE_HTTPS=true, TLS_KEY_PATH and TLS_CERT_PATH are required.
ENABLE_HTTPS=false
TLS_KEY_PATH=
TLS_CERT_PATH=
# Optional CA bundle path for client certificate chain validation
TLS_CA_PATH=

# Docker healthcheck command used by the stack compose files.
# Set this to an HTTP URL when ENABLE_HTTPS=false.
# Example: ONEROSTER_API_HEALTHCHECK_TEST=["CMD","curl","-f","http://localhost:3000/health-check"]
# Set this to an HTTPS URL when ENABLE_HTTPS=true.
# Example: ONEROSTER_API_HEALTHCHECK_TEST=["CMD","curl","-f","https://localhost:3000/health-check","--insecure"]
ONEROSTER_API_HEALTHCHECK_TEST=["CMD","curl","-f","http://localhost:3000/health-check"]
