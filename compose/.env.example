# Common
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Database engine pgsql or mssql
DB_ENGINE=pgsql
DB_SSL=false # or "true" if you want encryption
DB_TRUST_CERTIFICATE=false # or "true" if you want to trust the server certificate
DB_TTL_IN_MINUTES=120 # Time to live for DB sessions in minutes

# # MSSQL Configuration (uncomment to use SQL Server instead of PostgreSQL)
# MSSQL_PORT_EXPOSED=1433
# MSSQL_ACCEPT_EULA=Y
# MSSQL_SA_PASSWORD=YourStrong!Passw0rd
# MSSQL_IMAGE_TAG=2022-latest

NPG_POOLING_ENABLED=true
NPG_API_MAX_POOL_SIZE_ODS=20
NPG_API_MAX_POOL_SIZE_ADMIN=20
NPG_API_MAX_POOL_SIZE_SECURITY=20
NPG_API_MAX_POOL_SIZE_MASTER=20

TPDM_ENABLED=true
LOGS_FOLDER=./logs
BASE_URL=https://localhost
BASE_URL_DEV=http://localhost:3333
ALLOWED_ORIGINS=${BASE_URL}

# Ed-Fi v7.3.0
# Next two lines are for the minimal template
# ODS_DB_IMAGE_7X=ods-api-db-ods-minimal
# ODS_DB_TAG_7X=v7.3@sha256:579a324a39d8439f1b4087112f586ba665ca292e8ddaf3923b6718f11ac8ab0e

# These two are for the populated template
ODS_DB_IMAGE_7X=ods-api-db-ods-sandbox
ODS_DB_TAG_7X=v7.3@sha256:154ae3e8e666c99f57ece35a7d0ae596f7e38fed9daf164d7c37eb171777f121

# ODS_API_TAG_7X=v7.3@sha256:cd359af95d9cdb68753c67037b9c89f2103c0f706db34bba291321b396e16869
ODS_API_TAG_7X=pre
SWAGGER_TAG_7X=pre
SANDBOX_ADMIN_API_TAG_7X=pre

ADMIN_DB_TAG_7X=pre
#ADMIN_DB_TAG_7X=v2.2.1@sha256:1d69fa553fcd3e1d27a35485e2c0f428b95cf1a642dd019844a81af4def01714

# Generate a new encryption key using `openssl rand -base64 32`
ODS_CONNECTION_STRING_ENCRYPTION_KEY=vLgnKf+MyoAsEmeGsh+n+rKRN1bGS8s1b0eCo6zc5+o=

ODS_API_73_SINGLE_DISCOVERY=https://localhost/v7-single-api

# API Configuration for Node to trust the self-signed certificate
NODE_EXTRA_CA_CERTS=/app/ssl/server.crt

V7_SINGLE_API_VIRTUAL_NAME=v7-single-api
ONEROSTER_API_VIRTUAL_NAME=oneroster-api
SANDBOX_ADMIN_VIRTUAL_NAME=admin
DOCS_VIRTUAL_NAME=docs

ADMIN_USER=admin
ADMIN_PASSWORD=admin123
MINIMAL_KEY=minimal-key
MINIMAL_SECRET=minimal-secret
POPULATED_KEY=populated-key
POPULATED_SECRET=populated-secret

V7_SINGLE_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"
SANDBOX_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
SWAGGER_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"

NPG_SANDBOX_MAX_POOL_SIZE_ODS=20
NPG_SANDBOX_MAX_POOL_SIZE_ADMIN=20
NPG_SANDBOX_MAX_POOL_SIZE_SECURITY=20
NPG_SANDBOX_MAX_POOL_SIZE_MASTER=20

MULTITENANCY_ENABLED=false
PAGING_OFFSET=0
PAGING_LIMIT=25
ENABLE_APPLICATION_RESET_ENDPOINT=true

# oneroster-specific settings
ONEROSTER_API_VIRTUAL_NAME=oneroster-api
PORT=3000
DB_TYPE=postgres
API_BASE_PATH=

DB_HOST=db-ods
DB_USER=${POSTGRES_USER}
DB_PASS=${POSTGRES_PASSWORD}
DB_PORT=5432
DB_NAME=EdFi_Ods_Sandbox_${POPULATED_KEY}
# set to `prod` or `` (empty) for production
NODE_ENV=dev
DB_SSL=false
DB_SSL_CA=

# pg-boss settings:
PGBOSS_CRON=*/15 * * * *

CORS_ORIGINS=https://localhost/oneroster-api,https://localhost/docs

# OAuth2 settings - these must be filled out!
# (except for local testing - if blank, there's no auth, all requests will succeed)
OAUTH2_ISSUERBASEURL=https://localhost/v7-single-api
OAUTH2_AUDIENCE=https://localhost/oneroster-api
OAUTH2_TOKENSIGNINGALG=RS256
OAUTH2_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA4d3hJVRhxoIRM1/C0fWf\ngy3pKZflZT1TTisSfVPp2d2gcY8cm+5q7DYih5lM7FYhFAH3irISWiSXWeca1Bfv\nsItGLco0A3tT0dzQuB8RbZHdZF+HvN0AudU1Th2s7ugnxZ6YB4tOolSXWJaqz/81\nm9PByWxS+paduwnYw8fnZPyKaia0H8I/Mmy/eHbsKUYklknRSF+Z6AQxP9zJkafD\neiUwbNasKgUU7nLMC3OR+9zAXoQIFdB3gI8pbDjt+fFUO3PPhtXknAIBAVUxuWS6\nceIVSKZJHfqDwkAvjSySab0i79YT5bb7UZD5jnFKcZzBHuBfz4fKulLoAa9lXkfX\nPQIDAQAB\n-----END PUBLIC KEY-----
