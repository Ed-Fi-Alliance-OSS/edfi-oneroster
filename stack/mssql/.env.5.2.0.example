# MSSQL single-tenant sandbox example for Ed-Fi Data Standard 5.2.0
# Copy this file to .env and replace the placeholder secrets before starting the
# MSSQL sandbox compose files.

SQLSERVER_USER=sqlserver
SQLSERVER_PASSWORD=<your_sqlserver_password>
MSSQL_PID=Express

DB_ENGINE=mssql
DB_TYPE=mssql

TPDM_ENABLED=true
LOGS_FOLDER=./logs
BASE_URL=https://localhost
BASE_URL_DEV=http://localhost:3333
ALLOWED_ORIGINS=${BASE_URL}

STANDARD_VERSION=5.2.0
MSSQL_ODS_POPULATED_VERSION=5.2.0
MSSQL_TPDM_POPULATED_VERSION=5.2.0
MSSQL_ODS_MINIMAL_VERSION=5.2.0
MSSQL_TPDM_MINIMAL_VERSION=5.2.0
MSSQL_ADMIN_VERSION=5.2.0
MSSQL_SECURITY_VERSION=5.2.0
EXTENSION_VERSION=<tpdm_extension_version>

ODS_CONNECTION_STRING_ENCRYPTION_KEY=

ODS_API_VIRTUAL_NAME=api
ONEROSTER_API_VIRTUAL_NAME=oneroster-api
DOCS_VIRTUAL_NAME=swagger

LEA_KEY=<bootstrap api client key, authorized for LEA access>
LEA_SECRET=<bootstrap api client secret, authorized for LEA access>
SCHOOL_KEY=<bootstrap api client key, authorized for SCHOOL access>
SCHOOL_SECRET=<bootstrap api client secret, authorized for SCHOOL access>

ODS_API_HEALTHCHECK="wget --no-check-certificate --spider http://localhost/health"
SWAGGER_HEALTHCHECK_TEST="wget --no-check-certificate --spider http://localhost/health"
ONEROSTER_API_HEALTHCHECK_TEST="curl -f http://localhost:3000/health-check"

PAGING_OFFSET=0
PAGING_LIMIT=25
ENABLE_APPLICATION_RESET_ENDPOINT=true

TARGET_DB=EdFi_Ods
TEMPLATE_DB=EdFi_Ods_Populated_Template

ONEROSTER_IMAGE=edfialliance/one-roster-api:pre
PORT=3000
API_BASE_PATH=
NODE_ENV=dev

ONEROSTER_ARTIFACT_VERSION=5.2.0
ONEROSTER_ARTIFACT_DIR=/app/standard/${ONEROSTER_ARTIFACT_VERSION}/artifacts/mssql/core
CONNECTION_CONFIG={"adminConnection":"server=db-admin;database=EdFi_Admin;user id=<your_sqlserver_user>;password=<your_sqlserver_password>;encrypt=false;TrustServerCertificate=true"}

OAUTH2_ISSUERBASEURL=${BASE_URL}/${ODS_API_VIRTUAL_NAME}
OAUTH2_AUDIENCE=${BASE_URL}/${ONEROSTER_API_VIRTUAL_NAME}
OAUTH2_TOKENSIGNINGALG=RS256
OAUTH2_PUBLIC_KEY_PEM=${SECURITY__JWT__PUBLICKEY}

TRUST_PROXY=true

MULTITENANCY_ENABLED=false
ODS_CONTEXT_ROUTE_TEMPLATE=
TENANTS_CONNECTION_CONFIG=
ODS_INSTANCES=

ENABLE_HTTPS=false
TLS_KEY_PATH=
TLS_CERT_PATH=
TLS_CA_PATH=

# Signing keys for JWT issuance (set here or run start-services.ps1 -GenerateSigningKeys)
SECURITY__JWT__PRIVATEKEY=-----BEGIN PRIVATE KEY-----\nMIIEPAoGBALa7i/4j5gCc4bA5pWud\n-----END PRIVATE KEY-----
SECURITY__JWT__PUBLICKEY=-----BEGIN PUBLIC KEY-----\nMIQAB\n-----END PUBLIC KEY-----
